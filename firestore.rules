rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Master Catch-all Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    
    function isRootAdmin() {
      return isSignedIn() && request.auth.token.email == 'admin@guruai.internal';
    }

    // --- Validation Blueprints ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 128 &&
             data.role in ['admin', 'user'] &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 256));
    }

    function isValidProgress(data) {
      return data.keys().hasAll(['userId']) &&
             data.userId is string && data.userId.size() <= 128 &&
             (!('identity' in data) || data.identity is map) &&
             (!('cumulativeResults' in data) || data.cumulativeResults is map) &&
             (!('currentStep' in data) || data.currentStep is number) &&
             (!('currentContent' in data) || (data.currentContent is string && data.currentContent.size() <= 500000));
    }

    // --- Collection Routes ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if (isOwner(userId) || isAdmin()) && isValidUser(incoming()) && (
        (incoming().role == 'admin' ? isRootAdmin() || isAdmin() : true)
      );
      
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(incoming()) && (
        // Action: Change Profile (owner can change name etc, but NOT role)
        (isOwner(userId) && !incoming().diff(existing()).affectedKeys().hasAny(['role', 'uid', 'email'])) ||
        // Action: Change Role or Profile (admin can change roles and displayName)
        (isAdmin() && !incoming().diff(existing()).affectedKeys().hasAny(['uid', 'email']))
      );
      
      allow delete: if isAdmin() && userId != request.auth.uid; // Prevent self-deletion
    }

    match /access_logs/{logId} {
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow read, delete: if isAdmin();
    }

    match /progress/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      // Strict validation for writes
      allow create: if (isOwner(userId) || isAdmin()) && isValidProgress(incoming()) && (
        incoming().userId == userId
      );
      
      allow update: if (isOwner(userId) || isAdmin()) && isValidProgress(incoming()) && (
        !incoming().diff(existing()).affectedKeys().hasAny(['userId'])
      );
      
      allow delete: if isAdmin();
    }
  }
}
